{
  "name": "osrcore-docs",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "docs:split": "node scripts/split-docs.mjs",
    "i18n:check": "node scripts/split-docs.mjs && node scripts/check-i18n.mjs",
    "dev": "node scripts/split-docs.mjs && vitepress dev . --host 0.0.0.0",
    "build": "node scripts/split-docs.mjs && node scripts/check-i18n.mjs && vitepress build .",
    "preview": "vitepress preview . --host 0.0.0.0"
  },
  "devDependencies": {
    "vitepress": "^1.6.4"
  }
}
